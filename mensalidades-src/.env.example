# Configuração do projeto Firebase (Mutantes Moto Clube).
# Copie este arquivo para ".env" e preencha com os valores reais do seu projeto
# (Firebase Console > Configurações do projeto > Seus apps > app Web > Configuração do SDK).
#
# Estas chaves são PÚBLICAS por design (não são segredos) — ver comentário em
# src/firebase/config.ts para mais detalhes. Ainda assim ficam em variável de
# ambiente, não hardcoded, para facilitar trocar de projeto sem editar código.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Chave pública de Web Push (VAPID), necessária para ativar notificações push.
# Gerada em: Firebase Console > Configurações do projeto > Cloud Messaging >
# Web Push certificates > Gerar par de chaves.
VITE_FIREBASE_VAPID_KEY=
