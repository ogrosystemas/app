rules_version = '2';

// Regras de segurança do Firestore — Mutantes Moto Clube.
//
// Modelo de autorização: uma lista fixa de e-mails autorizados, mantida aqui mesmo
// (não em um documento do banco, para evitar o problema de "a regra que protege a
// lista de autorizados depender da própria lista de autorizados"). Qualquer pessoa
// pode fazer login com Google (isso é só autenticação), mas só os e-mails desta
// lista conseguem de fato ler ou escrever os dados do clube (isso é autorização).
//
// Para adicionar ou remover alguém: edite a função emailAutorizado() abaixo
// (adicione/remova uma linha "|| request.auth.token.email == '...'") e publique
// as regras de novo (Firebase Console > Firestore Database > Regras > colar o
// conteúdo deste arquivo > Publicar).
function emailAutorizado() {
  return request.auth != null && (
    request.auth.token.email == 'tibabarcelos@gmail.com'
    // Para adicionar uma nova pessoa autorizada, adicione uma linha assim:
    // || request.auth.token.email == 'outrapessoa@gmail.com'
  );
}

service cloud.firestore {
  match /databases/{database}/documents {

    // Todo o caminho do clube (documento de config + subcoleções de membros e
    // pagamentos) segue a mesma regra: só e-mails autorizados leem ou escrevem,
    // qualquer outra pessoa (autenticada ou não) é sempre rejeitada.
    match /clubes/{clubeId} {
      allow read, write: if emailAutorizado();

      match /membros/{membroId} {
        allow read, write: if emailAutorizado();
      }

      match /pagamentos/{pagamentoId} {
        allow read, write: if emailAutorizado();
      }
    }

    // Qualquer outro caminho não previsto explicitamente acima é sempre negado —
    // postura "tudo bloqueado por padrão", igual ao modo de produção inicial
    // gerado pelo próprio Firebase.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
