rules_version = '2';

// Regras de segurança do Firestore — Mutantes Moto Clube.
//
// Existem DOIS níveis de acesso, bem diferentes entre si:
//
// 1) ADMINISTRADOR — lista fixa de e-mails mantida aqui mesmo (função
//    emailAutorizado() abaixo), não em um documento do banco — isso evita o
//    problema de "a regra que protege a lista de administradores depender da
//    própria lista de administradores". Administradores leem e escrevem tudo.
//
// 2) INTEGRANTE COMUM — qualquer membro cadastrado pode, opcionalmente, ter um
//    e-mail vinculado (campo `emailAcesso` no cadastro do membro, gerenciado
//    pelo app). Esse vínculo é espelhado num documento em `acessos/{email}`
//    (coleção na raiz do banco, fora do caminho do clube) que serve como
//    "porteiro": sua mera existência e conteúdo (qual membroId) é o que a
//    regra abaixo consulta para decidir se aquele e-mail pode ler (nunca
//    escrever, exceto para criar os próprios avisos de pagamento) os dados
//    de UM ÚNICO membro específico — nunca a lista inteira, nunca os dados de
//    outros membros.
//
// Para adicionar/remover um ADMINISTRADOR: edite emailAutorizado() abaixo e
// publique de novo. Para vincular/desvincular um INTEGRANTE COMUM: isso é
// feito dentro do próprio app (campo "E-mail de acesso" no cadastro do
// membro) — não exige editar estas regras.
function emailAutorizado() {
  return request.auth != null && (
    request.auth.token.email == 'tibabarcelos@gmail.com'
    // Para adicionar um novo administrador, adicione uma linha assim:
    // || request.auth.token.email == 'outrapessoa@gmail.com'
  );
}

// true se o usuário autenticado tem um vínculo de acesso (qualquer um) registrado
// em acessos/{email} — não diz ainda a qual membro está vinculado, só que existe
// algum vínculo. Usado para liberar leitura da config do clube (necessária para
// calcular o status de qualquer membro) sem expor a lista de outros membros.
//
// O e-mail é normalizado com .lower() antes de montar o caminho do documento,
// pois o app sempre grava o ID do documento em acessos/{email} em minúsculas
// (ver normalizarEmail em db/refs.ts) — sem essa normalização aqui, um token de
// autenticação que viesse com alguma letra maiúscula no e-mail (o que não é
// garantido pela especificação do OAuth) faria a checagem falhar incorretamente.
function temAcessoDeIntegranteQualquer() {
  return request.auth != null &&
    exists(/databases/$(database)/documents/acessos/$(request.auth.token.email.lower()));
}

// true se o usuário autenticado está vinculado ESPECIFICAMENTE ao membroId informado
// — usado para restringir leitura/criação aos dados do PRÓPRIO membro, nunca de outros.
function ehOProprioMembroVinculado(membroId) {
  return request.auth != null &&
    exists(/databases/$(database)/documents/acessos/$(request.auth.token.email.lower())) &&
    get(/databases/$(database)/documents/acessos/$(request.auth.token.email.lower())).data.membroId == membroId;
}

service cloud.firestore {
  match /databases/{database}/documents {

    match /clubes/{clubeId} {
      // Config do clube (nome, valor da mensalidade): administradores leem e
      // escrevem; qualquer integrante vinculado a ALGUM membro pode só LER
      // (precisa do valorMensalidade para calcular o próprio status).
      allow read: if emailAutorizado() || temAcessoDeIntegranteQualquer();
      allow write: if emailAutorizado();

      match /membros/{membroId} {
        // Administradores leem e escrevem qualquer membro. Um integrante comum
        // só pode LER o próprio documento — nunca a lista inteira (uma query
        // "list" exigiria que a regra valesse para todo membro do resultado,
        // o que nunca acontece aqui exceto para o admin) e nunca escrever.
        allow read: if emailAutorizado() || ehOProprioMembroVinculado(membroId);
        allow write: if emailAutorizado();
      }

      match /pagamentos/{pagamentoId} {
        // Pagamentos: só administradores leem/escrevem. Um integrante comum
        // consulta o próprio histórico de pagamentos através do app (que filtra
        // por membroId), mas a regra abaixo só libera leitura quando o
        // documento de pagamento já teve seu campo membroId carregado — como
        // isso exige ler o próprio recurso, usamos resource.data.membroId.
        allow read: if emailAutorizado() || ehOProprioMembroVinculado(resource.data.membroId);
        allow write: if emailAutorizado();
      }

      match /avisos/{avisoId} {
        // Administradores leem e escrevem todos os avisos (para ver os lembretes
        // de pagamento). Um integrante comum pode LER e CRIAR avisos somente em
        // seu próprio nome — precisa de leitura para o app saber se já existe um
        // aviso daquela competência (e mostrar "Avisado" em vez do botão "Vou
        // pagar" de novo) — mas nunca editar/excluir, nem ler avisos de outros.
        allow read: if emailAutorizado() || ehOProprioMembroVinculado(resource.data.membroId);
        allow create: if emailAutorizado() || ehOProprioMembroVinculado(request.resource.data.membroId);
        allow update, delete: if emailAutorizado();
      }
    }

    // Coleção "porteiro" de vínculos e-mail -> membroId. Só administradores podem
    // escrever (vincular/desvincular alguém). Um integrante comum só pode LER o
    // PRÓPRIO documento (nunca o de outro e-mail) — necessário para o app
    // descobrir, no primeiro login, a qual membro aquele e-mail está vinculado.
    // O ID do documento (variável `email`) já é gravado em minúsculas pelo app
    // (ver normalizarEmail em db/refs.ts), por isso comparamos com
    // request.auth.token.email.lower() em vez do valor "crú" do token.
    match /acessos/{email} {
      allow read: if emailAutorizado() ||
        (request.auth != null && request.auth.token.email.lower() == email);
      allow write: if emailAutorizado();
    }

    // Qualquer outro caminho não previsto explicitamente acima é sempre negado —
    // postura "tudo bloqueado por padrão", igual ao modo de produção inicial
    // gerado pelo próprio Firebase.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
