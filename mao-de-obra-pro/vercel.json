{
  "buildCommand": "cd mao-de-obra-pro && npm run build",
  "outputDirectory": "mao-de-obra-pro/dist",
  "devCommand": "cd mao-de-obra-pro && npm run dev",
  "installCommand": "cd mao-de-obra-pro && npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}